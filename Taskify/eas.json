{
  "cli": {
    "version": ">= 18.0.5",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": true
      },
      "channel": "development",
      "env": {
        "GOOGLE_SERVICES_BASE64": "will-be-injected-from-eas-secrets"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview"
    },
    "production": {
      "autoIncrement": true,
      "channel": "production"
    },
    "production-apk": {
      "autoIncrement": true,
      "android": {
        "buildType": "apk"
      },
      "env": {
        "SENTRY_AUTH_TOKEN": "will-be-injected-from-eas-secrets",
        "GOOGLE_SERVICES_BASE64": "will-be-injected-from-eas-secrets"
      },
      "channel": "production-apk"
    },
    "production-ios": {
      "autoIncrement": true,
      "ios": {
        "simulator": false
      },
      "env": {
        "SENTRY_AUTH_TOKEN": "will-be-injected-from-eas-secrets",
        "GOOGLE_SERVICES_BASE64": "will-be-injected-from-eas-secrets"
      },
      "channel": "production-ios"
    }
  },
  "submit": {
    "production": {}
  }
}
